import Mdi.Config
import Svg exposing (Svg)


{-| An opaque type for an icon.
-}
type alias Icon =
    Mdi.Config.Icon


{-| The string can be any CSS-compliant color string.
-}
decorationColor : String -> Icon -> Icon
decorationColor color icon =
    icon


{-| Uses the outline version of the icon.

If an outline version doesn't exist, it will just continue using the non-outline
version.

-}
outline : Icon -> Icon
outline icon =
    icon


{-| Renders an [Icon](#Icon) to Svg.
-}
toSvg : Icon -> Svg msg
toSvg (Mdi.Config.Icon config) =
    Svg.svg
        []
        []


{-| Decorates the icon with a person in the lower right corner

    Mdi.Icons.airballoon
        |> Mdi.outline
        |> Mdi.account

![account](data:image/svg+xml;base64,)

-}
account : Icon -> Icon
account icon =
    icon


