{-| Look up an icon (which has the first letter "q") by its name.

    let accountIcon =
        Material.Icons.Directory.lookup "account"

-}
lookup : String -> Maybe IconShape
lookup name =
    case name of
        "qrcode" ->
            Just qrcode

        "qrcode-minus" ->
            Just qrcodeMinus

        "qrcode-edit" ->
            Just qrcodeEdit

        "qrcode-plus" ->
            Just qrcodePlus

        "qrcode-remove" ->
            Just qrcodeRemove

        "qrcode-scan" ->
            Just qrcodeScan

        "quality-high" ->
            Just qualityHigh

        "quadcopter" ->
            Just quadcopter

        "quality-low" ->
            Just qualityLow

        "quality-medium" ->
            Just qualityMedium

        "queue-first-in-last-out" ->
            Just queueFirstInLastOut

        _ ->
            Nothing
