{-| Look up an icon (which has the first letter "u") by its name.

    let accountIcon =
        Material.Icons.Directory.lookup "account"

-}
lookup : String -> Maybe IconShape
lookup name =
    case name of
        "ufo" ->
            Just ufo

        "ufo-outline" ->
            Just ufoOutline

        "ultra-high-definition" ->
            Just ultraHighDefinition

        "umbrella" ->
            Just umbrella

        "umbrella-beach" ->
            Just umbrellaBeach

        "umbrella-beach-outline" ->
            Just umbrellaBeachOutline

        "umbrella-closed" ->
            Just umbrellaClosed

        "umbrella-closed-outline" ->
            Just umbrellaClosedOutline

        "umbrella-closed-variant" ->
            Just umbrellaClosedVariant

        "umbrella-outline" ->
            Just umbrellaOutline

        "underwear-outline" ->
            Just underwearOutline

        "undo" ->
            Just undo

        "undo-variant" ->
            Just undoVariant

        "unfold-less-horizontal" ->
            Just unfoldLessHorizontal

        "unfold-less-vertical" ->
            Just unfoldLessVertical

        "unfold-more-horizontal" ->
            Just unfoldMoreHorizontal

        "unfold-more-vertical" ->
            Just unfoldMoreVertical

        "ungroup" ->
            Just ungroup

        "unicorn" ->
            Just unicorn

        "unicorn-variant" ->
            Just unicornVariant

        "unicycle" ->
            Just unicycle

        "update" ->
            Just update

        "upload" ->
            Just upload

        "upload-box" ->
            Just uploadBox

        "upload-box-outline" ->
            Just uploadBoxOutline

        "upload-circle" ->
            Just uploadCircle

        "upload-circle-outline" ->
            Just uploadCircleOutline

        "upload-lock" ->
            Just uploadLock

        "upload-lock-outline" ->
            Just uploadLockOutline

        "upload-multiple" ->
            Just uploadMultiple

        "upload-multiple-outline" ->
            Just uploadMultipleOutline

        "upload-network" ->
            Just uploadNetwork

        "upload-network-outline" ->
            Just uploadNetworkOutline

        "upload-off" ->
            Just uploadOff

        "upload-off-outline" ->
            Just uploadOffOutline

        "upload-outline" ->
            Just uploadOutline

        "usb" ->
            Just usb

        "usb-c-port" ->
            Just usbCPort

        "usb-flash-drive" ->
            Just usbFlashDrive

        "usb-flash-drive-outline" ->
            Just usbFlashDriveOutline

        "usb-port" ->
            Just usbPort

        _ ->
            Nothing
